{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prompt Frontmatter",
  "type": "object",
  "required": [
    "suite_id",
    "prompt_id",
    "sequence",
    "title",
    "canonical_path",
    "category",
    "prompt_role",
    "prompt_type",
    "status",
    "description",
    "paired_prompt_id",
    "pairing_required",
    "default_mode",
    "allowed_modes",
    "risk_level",
    "change_surface",
    "dry_run_required",
    "requires",
    "output_contract",
    "template_routes",
    "template_policy"
  ],
  "properties": {
    "suite_id": {
      "const": "mission-directives"
    },
    "prompt_id": {
      "pattern": "^MD-[0-9]{2,3}$"
    },
    "sequence": {
      "type": "integer"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "canonical_path": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "prompt_role": {
      "enum": [
        "control",
        "investigative",
        "executive",
        "operational",
        "gate"
      ]
    },
    "prompt_type": {
      "type": "string"
    },
    "status": {
      "const": "stable"
    },
    "description": {
      "type": "string"
    },
    "paired_prompt_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "pairing_required": {
      "type": "boolean"
    },
    "default_mode": {
      "type": "string"
    },
    "allowed_modes": {
      "type": "array"
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "change_surface": {
      "type": "string"
    },
    "dry_run_required": {
      "type": "boolean"
    },
    "requires": {
      "type": "array"
    },
    "output_contract": {
      "type": "object"
    },
    "template_routes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]+/[a-z0-9-]+$"
      }
    },
    "template_policy": {
      "const": "required_resolve_then_conditionally_select_by_requested_artifact"
    },
    "conditional_template_routes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]+/[a-z0-9-]+$"
      }
    }
  },
  "additionalProperties": true
}
