      "route_family": "visual-production",
      "priority": 90
    },
    {
      "keyword": "strudel",
      "target": "C-110",
      "purpose": "Strudel composition and bounded refinement",
      "route_family": "music-production",
      "priority": 90
    },
    {
      "keyword": "productivity",
      "target": "MD-138",
      "purpose": "personal knowledge, productivity, and work system",
      "route_family": "personal-productivity",
      "priority": 80
    }
  ],
  "supported_agent_files": [
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scope_note": "Only AGENTS.md and CLAUDE.md are managed. CODEX.md, PI.md, HERMES.md, OPENCODE.md, GEMINI.md, QWEN.md, CURSOR.md, WINDSURF.md, COPILOT.md, and custom filenames are intentionally excluded.",
