{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TUI Progress Event",
  "type": "object",
  "required": [
    "task_id",
    "label",
    "current",
    "total",
    "percent",
    "timestamp"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "label": {
      "type": "string"
    },
    "current": {
      "type": "integer",
      "minimum": 0
    },
    "total": {
      "type": "integer",
      "minimum": 1
    },
    "percent": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "timestamp": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
