{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/plan_review_receipt.schema.json",
  "title": "Paired Plan Review Receipt",
  "type": "object",
  "required": [
    "review_id",
    "planning_prompt_id",
    "execution_prompt_id",
    "reviewer",
    "reviewed_at",
    "decision",
    "handoff_hash",
    "revision_number"
  ],
  "properties": {
    "review_id": {
      "type": "string",
      "minLength": 1
    },
    "planning_prompt_id": {
      "type": "string",
      "pattern": "^MD-[0-9]{2,3}$"
    },
    "execution_prompt_id": {
      "type": "string",
      "pattern": "^MD-[0-9]{2,3}$"
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "changes_requested",
        "approved",
        "declined"
      ]
    },
    "feedback": {
      "type": "string"
    },
    "handoff_hash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+:.+$"
    },
    "revision_number": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
