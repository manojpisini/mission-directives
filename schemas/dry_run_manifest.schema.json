{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/dry_run_manifest.schema.json",
  "title": "Dry Run Manifest",
  "type": "object",
  "required": [
    "run_id",
    "actions",
    "change_surfaces",
    "side_effects",
    "rollback",
    "stop_conditions"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "preview"
        ],
        "properties": {
          "action_id": {
            "type": "string"
          },
          "preview": {
            "type": "string"
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "change_surfaces": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "side_effects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "object"
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
