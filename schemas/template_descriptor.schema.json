{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MD Template Descriptor",
  "type": "object",
  "required": [
    "template_id",
    "title",
    "family",
    "purpose",
    "path",
    "status",
    "required_by_prompt_ids"
  ],
  "properties": {
    "template_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+/[a-z0-9-]+$"
    },
    "title": {
      "type": "string"
    },
    "family": {
      "enum": [
        "core",
        "documentation",
        "presentation",
        "report",
        "visual"
      ]
    },
    "purpose": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "status": {
      "const": "stable"
    },
    "required_by_prompt_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^MD-[0-9]{2,3}$"
      }
    }
  },
  "additionalProperties": true
}
