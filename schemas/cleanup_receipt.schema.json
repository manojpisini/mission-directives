{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mission Directives Project Cleanup Result",
  "oneOf": [
    {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "project_root",
        "suite_version",
        "planned_removals",
        "managed_blocks",
        "preserved_paths",
        "warnings",
        "approval_token",
        "completed_at"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0"
        },
        "status": {
          "const": "dry_run"
        },
        "project_root": {
          "type": "string"
        },
        "suite_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "planned_removals": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "managed_blocks": {
          "type": "array",
          "items": {
            "enum": [
              ".gitignore",
              "AGENTS.md",
              "CLAUDE.md"
            ]
          },
          "uniqueItems": true
        },
        "preserved_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "approval_token": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "project_root",
        "suite_version",
        "removed_paths",
        "removed_managed_blocks",
        "deleted_empty_files",
        "preserved_paths",
        "warnings",
        "bytes_reclaimed",
        "completed_at",
        "duration_ms"
      ],
      "properties": {
        "schema_version": {
          "const": "1.0"
        },
        "status": {
          "const": "cleaned"
        },
        "project_root": {
          "type": "string"
        },
        "suite_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "removed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "removed_managed_blocks": {
          "type": "array",
          "items": {
            "enum": [
              ".gitignore",
              "AGENTS.md",
              "CLAUDE.md"
            ]
          },
          "uniqueItems": true
        },
        "deleted_empty_files": {
          "type": "array",
          "items": {
            "enum": [
              ".gitignore",
              "AGENTS.md",
              "CLAUDE.md"
            ]
          },
          "uniqueItems": true
        },
        "preserved_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "bytes_reclaimed": {
          "type": "integer",
          "minimum": 0
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "receipt_path": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  ]
}
