{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prompt_addition_receipt.schema.json",
  "type": "object",
  "required": [
    "status",
    "prompt_id",
    "sequence",
    "title",
    "slug",
    "canonical_path",
    "capability_id",
    "changed_files",
    "full_tests_run",
    "receipt_path",
    "suite_version",
    "category",
    "prompt_role",
    "prompt_type",
    "risk_level",
    "allowed_modes",
    "dry_run_required",
    "requires",
    "preferred_skills",
    "template_routes",
    "conditional_template_routes",
    "related_prompts",
    "department_packs",
    "source_sha256",
    "source_bytes",
    "approved_preview_sha256",
    "validation_status",
    "recorded_at"
  ],
  "properties": {
    "status": {
      "const": "pass"
    },
    "prompt_id": {
      "pattern": "^MD-[0-9]+$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0
    },
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 180
    },
    "slug": {
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "canonical_path": {
      "pattern": "^prompts/[0-9]{3}_[A-Z0-9_]+\\.md$"
    },
    "capability_id": {
      "pattern": "^md\\.[a-z0-9._-]+$"
    },
    "preferred_skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 128
    },
    "template_routes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 128
    },
    "conditional_template_routes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 128
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      },
      "maxItems": 4096
    },
    "full_tests_run": {
      "type": "boolean"
    },
    "receipt_path": {
      "pattern": "^\\.prompt_suite/results/prompt-addition/MD-[0-9]+-[0-9a-f]{12}\\.json$"
    },
    "suite_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "related_prompts": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "pattern": "^MD-[0-9]+$"
      },
      "maxItems": 128
    },
    "department_packs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      },
      "maxItems": 128
    },
    "source_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_bytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2097152
    },
    "validation_status": {
      "const": "pass"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "maxLength": 128
    },
    "prompt_role": {
      "enum": [
        "operational",
        "investigative",
        "gate",
        "control"
      ]
    },
    "prompt_type": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "maxLength": 128
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "allowed_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "AUDIT_ONLY",
          "PLAN_ONLY",
          "DRAFT_ONLY",
          "APPLY_SAFE",
          "APPLY_APPROVED",
          "VERIFY_ONLY"
        ]
      }
    },
    "dry_run_required": {
      "type": "boolean"
    },
    "requires": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^MD-[0-9]+$"
      },
      "maxItems": 128
    },
    "approved_preview_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
