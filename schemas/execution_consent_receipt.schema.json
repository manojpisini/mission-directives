{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/execution_consent_receipt.schema.json",
  "title": "Exact Twin Execution Consent Receipt",
  "type": "object",
  "required": [
    "consent_id",
    "planning_prompt_id",
    "execution_prompt_id",
    "user",
    "granted_at",
    "decision",
    "handoff_hash",
    "exact_twin_only"
  ],
  "properties": {
    "consent_id": {
      "type": "string",
      "minLength": 1
    },
    "planning_prompt_id": {
      "type": "string",
      "pattern": "^MD-[0-9]{2,3}$"
    },
    "execution_prompt_id": {
      "type": "string",
      "pattern": "^MD-[0-9]{2,3}$"
    },
    "user": {
      "type": "string",
      "minLength": 1
    },
    "granted_at": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "approved",
        "declined"
      ]
    },
    "handoff_hash": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+:.+$"
    },
    "exact_twin_only": {
      "const": true
    }
  },
  "additionalProperties": false
}
