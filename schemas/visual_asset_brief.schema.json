{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "visual_asset_brief.schema.json",
  "type": "object",
  "required": [
    "asset_id",
    "communication_job",
    "audience",
    "placement",
    "visual_form",
    "dimensions",
    "acceptance_rubric",
    "export_formats"
  ],
  "properties": {
    "asset_id": {
      "type": "string"
    },
    "communication_job": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "placement": {
      "type": "string"
    },
    "source_evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "primary_message": {
      "type": "string"
    },
    "secondary_details": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visual_form": {
      "type": "string"
    },
    "dimensions": {
      "type": "object"
    },
    "brand_tokens": {
      "type": "object"
    },
    "typography": {
      "type": "object"
    },
    "interaction_or_motion": {
      "type": "object"
    },
    "accessibility_alternative": {
      "type": "string"
    },
    "editability_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "export_formats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prohibited_elements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "criterion",
          "verification"
        ],
        "properties": {
          "criterion": {
            "type": "string"
          },
          "verification": {
            "type": "string"
          },
          "threshold": {}
        }
      }
    }
  },
  "additionalProperties": true
}
