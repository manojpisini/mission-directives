{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prompt_addition_preview.schema.json",
  "type": "object",
  "required": [
    "status", "suite_version", "catalog_sha256", "prompt_id", "sequence", "title", "slug",
    "canonical_path", "capability_id", "category", "prompt_role", "prompt_type", "risk_level",
    "allowed_modes", "dry_run_required", "requires", "related_prompts", "preferred_skills",
    "template_routes", "conditional_template_routes", "department_packs", "output_contract",
    "source_sha256", "source_bytes", "approval_token"
  ],
  "properties": {
    "status": {"const": "dry_run"},
    "suite_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "catalog_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "prompt_id": {"type": "string", "pattern": "^MD-[0-9]+$"},
    "sequence": {"type": "integer", "minimum": 0},
    "title": {"type": "string", "minLength": 3, "maxLength": 180},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "canonical_path": {"type": "string", "pattern": "^prompts/[0-9]{3}_[A-Z0-9_]+\\.md$"},
    "capability_id": {"type": "string", "pattern": "^md\\.[a-z0-9._-]+$"},
    "category": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "prompt_role": {"enum": ["operational", "investigative", "gate", "control"]},
    "prompt_type": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "allowed_modes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["AUDIT_ONLY", "PLAN_ONLY", "DRAFT_ONLY", "APPLY_SAFE", "APPLY_APPROVED", "VERIFY_ONLY"]}},
    "dry_run_required": {"type": "boolean"},
    "requires": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"type": "string", "pattern": "^MD-[0-9]+$"}},
    "related_prompts": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"type": "string", "pattern": "^MD-[0-9]+$"}},
    "preferred_skills": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"type": "string"}},
    "template_routes": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"type": "string"}},
    "conditional_template_routes": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"type": "string"}},
    "department_packs": {"type": "array", "uniqueItems": true, "maxItems": 128, "items": {"type": "string"}},
    "output_contract": {"type": "object"},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_bytes": {"type": "integer", "minimum": 1, "maximum": 2097152},
    "approval_token": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
